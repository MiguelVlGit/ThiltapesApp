<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F2A20">

    <!-- MAP -->
    <FrameLayout
        android:id="@+id/mapCriarContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- TOP CARD: nome + foto -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:cardCornerRadius="12dp"
        app:cardBackgroundColor="#CC0F2A20"
        app:cardElevation="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Novo Thiltape"
                android:textColor="#7ED0A5"
                android:textSize="12sp"
                android:textAllCaps="true"
                android:textStyle="bold" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:hint="Nome do thiltape"
                android:textColorHint="#AAAAAA"
                app:hintTextColor="#7ED0A5"
                app:boxStrokeColor="#7ED0A5"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etNomeThiltape"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#FFFFFF"
                    android:inputType="textCapSentences" />

            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTirarFoto"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="10dp"
                android:text="Tirar Foto"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textAllCaps="false"
                app:backgroundTint="#254D3D"
                app:cornerRadius="10dp"
                app:icon="@android:drawable/ic_menu_camera"
                app:iconTint="#7ED0A5"
                app:iconGravity="textStart" />

            <ImageView
                android:id="@+id/ivPreviewFoto"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:layout_marginTop="8dp"
                android:scaleType="centerCrop"
                android:visibility="gone"
                android:background="#1A7ED0A5" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- HINT LABEL: tap to place -->
    <TextView
        android:id="@+id/tvTapHint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true"
        android:layout_centerInParent="true"
        android:text="Toque no mapa para posicionar o thiltape"
        android:textColor="#CCFFFFFF"
        android:textSize="13sp"
        android:background="#99000000"
        android:padding="8dp" />

    <!-- BOTTOM BAR -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="horizontal"
        android:background="#CC0F2A20"
        android:padding="16dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBackCriar"
            style="@style/Widget.MaterialComponents.Button.Icon"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:padding="0dp"
            android:insetLeft="0dp"
            android:insetTop="0dp"
            android:insetRight="0dp"
            android:insetBottom="0dp"
            app:icon="@android:drawable/ic_menu_revert"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconSize="24dp"
            app:iconTint="#FFFFFF"
            app:cornerRadius="28dp"
            android:backgroundTint="#254D3D"
            android:layout_marginEnd="16dp"
            android:contentDescription="Voltar" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSalvarThiltape"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:text="Salvar Thiltape"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textAllCaps="false"
            app:backgroundTint="#FF9800"
            app:cornerRadius="12dp" />

    </LinearLayout>

</RelativeLayout>