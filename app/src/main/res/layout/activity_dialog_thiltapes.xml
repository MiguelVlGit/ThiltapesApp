<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="320dp"
    android:layout_height="wrap_content"
    android:layout_gravity="center"
    app:cardCornerRadius="24dp"
    app:cardBackgroundColor="#1B3A2E"
    app:cardElevation="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:gravity="center">

        <!-- MENSAGEM DE ENCONTRO -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Você encontrou um Thiltapes!"
            android:textColor="#7ED0A5"
            android:textSize="14sp"
            android:textAllCaps="true"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:layout_marginBottom="16dp"
            android:textAlignment="center"/>

        <!-- IMAGENZONA DO THILTAPES -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="200dp"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="#0F2A20"
            android:layout_marginBottom="12dp">

            <ImageView
                android:id="@+id/imgThiltapesFound"
                android:layout_width="match_parent"
                android:layout_height="parent"
                android:scaleType="centerCrop"
                android:src="@drawable/thiltapes_foto_1"
                android:contentDescription="Foto do Thiltapes Encontrado" />
        </androidx.cardview.widget.CardView>

        <!-- RECOMPENSA DE XP (O QUE FALTAVA!) -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">

            <TextView
                android:id="@+id/tvXpReward"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="+50 XP"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- BOTÃO DE CAPTURAR -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCaptureConfirm"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Capturar"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="16sp"
            app:cornerRadius="12dp"
            android:backgroundTint="#FF9800"
            android:textAllCaps="false"
            app:elevation="4dp"/>

    </LinearLayout>
</androidx.cardview.widget.CardView>
