<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F2A20">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- HEADER COM GRADIENTE -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:paddingTop="48dp"
                android:paddingBottom="24dp"
                android:paddingLeft="24dp"
                android:paddingRight="24dp"
                android:background="#1B3A2E">

                <ImageView
                    android:id="@+id/imgHeaderUserV12"
                    android:layout_width="160dp"
                    android:layout_height="80dp"
                    android:adjustViewBounds="true"
                    android:contentDescription="Logo Caça ao Thiltapes"
                    android:scaleType="fitCenter"
                    android:src="@drawable/logo_thiltapes" />

                <TextView
                    android:id="@+id/tvWelcome"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Bem-vindo!"
                    android:textColor="#FFFFFF"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:layout_marginTop="16dp"/>

                <TextView
                    android:id="@+id/tvChooseAdventure"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Escolha sua próxima aventura"
                    android:textColor="#7ED0A5"
                    android:textSize="14sp"
                    android:layout_marginTop="4dp"/>

            </LinearLayout>

            <!-- CONTEÚDO -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingLeft="20dp"
                android:paddingRight="20dp"
                android:paddingTop="24dp"
                android:paddingBottom="32dp">

                <!-- LINHA: TÍTULO + SAIR + RANKING -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvPanelTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Painel do Aventureiro"
                            android:textColor="#7ED0A5"
                            android:textSize="11sp"
                            android:textAllCaps="true"
                            android:letterSpacing="0.12"
                            android:fontFamily="sans-serif-medium"/>

                        <TextView
                            android:id="@+id/btnLogout"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sair"
                            android:textColor="#FF6B6B"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:paddingTop="2dp"/>
                    </LinearLayout>

                    <androidx.cardview.widget.CardView
                        android:id="@+id/btnRankingCreative"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:clickable="true"
                        android:focusable="true"
                        app:cardCornerRadius="20dp"
                        app:cardBackgroundColor="#1B3A2E"
                        app:cardElevation="4dp">

                    </androidx.cardview.widget.CardView>

                </RelativeLayout>

                <!-- DIVISOR -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#1F7ED0A5"
                    android:layout_marginBottom="20dp"/>

                <!-- LISTA DE JOGOS -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvJogos"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"/>

            </LinearLayout>
        </LinearLayout>
    </ScrollView>

</RelativeLayout>